:80 {
    root * /usr/share/caddy
    file_server
    
    encode gzip
    
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Cache-Control "public, max-age=31536000"
    }
    
    log {
        output stdout
        format json
    }
}
